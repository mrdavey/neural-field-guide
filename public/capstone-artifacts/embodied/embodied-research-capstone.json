{
  "schemaVersion": 1,
  "course": "embodied",
  "lessonId": "embodied-research-capstone",
  "evidenceKind": "reviewed deterministic local NumPy teaching fixture",
  "starter": {
    "publicUrl": "capstone-artifacts/embodied/embodied_capstone_starter.py",
    "requirementsUrl": "capstone-artifacts/embodied/requirements-capstones.txt",
    "command": "python3 embodied_capstone_starter.py --project embodied-research-capstone --profile smoke --output embodied-research-capstone-smoke.json",
    "expected": "All eleven pinned-baseline, profile-seed, complete-matrix, required-field, pairing, one-change, recomputation, deadline, horizon, assistance, and paired-effect checks are true.",
    "boundary": "This command executes a pinned deterministic one-dimensional teaching study locally; it is not an external benchmark, physical-robot measurement, real timing study, or general embodied conclusion."
  },
  "implementation": {
    "requiredComponents": [
      "portable-linear-reach-v1 pinned baseline",
      "embodied-starter/2.0 implementation revision and numpy==2.4.4 dependency",
      "smoke and bounded full seed profiles",
      "paired baseline gain 0.35 and treatment gain 0.55 rollouts",
      "matched initial state, disturbance, horizon, action, call, and scheduled-tick budgets",
      "complete seed-by-arm raw trajectory writer",
      "hard deadline and assistance/autonomy gates",
      "built-in raw-trajectory and metric recomputation verifier",
      "paired final-error analysis and bounded decision"
    ],
    "buildOrder": [
      "Install numpy==2.4.4 and run tests/test_research_study.py",
      "Freeze portable-linear-reach-v1, embodied-starter/2.0, gains, profiles, horizon, action bound, ticks, and success tolerance",
      "Run smoke seeds 101, 202, and 303 for baseline gain 0.35 and treatment gain 0.55",
      "Reconcile all six paired rows and verify only controllerGain changes within each seed",
      "Recompute initial states, disturbances, every transition, final errors, success, deadlines, assistance labels, and paired effects from raw traces",
      "Run the built-in --verify-study receipt, then execute the bounded twelve-seed full profile before any broader interpretation"
    ],
    "localCommands": [
      "python3 -m pip install -r requirements-capstones.txt",
      "python3 -m unittest tests/test_research_study.py",
      "python3 -m unittest discover -s tests -p 'test_*.py'",
      "python3 embodied_capstone_starter.py --project embodied-research-capstone --profile smoke --output embodied-research-capstone-smoke.json",
      "python3 embodied_capstone_starter.py --verify-study embodied-research-capstone-smoke.json",
      "python3 embodied_capstone_starter.py --project embodied-research-capstone --profile full --output embodied-research-capstone-full.json"
    ],
    "artifacts": [
      "embodied-research-capstone-smoke.json",
      "embodied-research-capstone-full.json",
      "built-in verifier receipt",
      "all seed-by-arm traces",
      "pairedEffects",
      "failure.log"
    ]
  },
  "acceptanceChecks": [
    {
      "id": "pinned-portable-baseline",
      "action": "Inspect the smoke manifest before execution for baseline ID, implementation revision, dependency, seeds, gains, horizon, action limit, and scheduled ticks.",
      "expected": "It pins portable-linear-reach-v1 at embodied-starter/2.0 with numpy==2.4.4, seeds 101/202/303, gain 0.35 versus 0.55, and no external assets."
    },
    {
      "id": "paired-recomputation",
      "action": "Join the Cartesian product of three smoke seeds and two arms, then recompute every rollout transition and summary metric from its pinned seed and raw trace.",
      "expected": "Exactly six unique rows exist; pair IDs, initial states, disturbance hashes, budgets, scheduled ticks, assistance/autonomy labels, and trace lengths match while controllerGain is the only changed field."
    },
    {
      "id": "independent-verifier",
      "action": "Run python3 embodied_capstone_starter.py --verify-study embodied-research-capstone-smoke.json after the smoke project command.",
      "expected": "The built-in verifier independently returns all eleven checks true; any missing, duplicate, forged, coordinated gain, treatment-only assistance, paired-effect, or deadline fault blocks the study."
    }
  ],

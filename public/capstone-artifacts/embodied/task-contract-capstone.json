{
  "schemaVersion": 1,
  "course": "embodied",
  "lessonId": "task-contract-capstone",
  "evidenceKind": "reviewed deterministic local NumPy teaching fixture",
  "starter": {
    "publicUrl": "capstone-artifacts/embodied/embodied_capstone_starter.py",
    "requirementsUrl": "capstone-artifacts/embodied/requirements-capstones.txt",
    "command": "python3 embodied_capstone_starter.py --project task-contract-capstone --profile smoke --output task-contract-capstone-smoke.json",
    "expected": "All eleven typed-packet, replay, requested/applied, predicate, oracle, stale/future observation, stale/future action, and wrong-frame checks are true.",
    "boundary": "This command executes the deterministic one-dimensional task contract locally; it does not run a learned policy, external simulator, or physical robot."
  },
  "implementation": {
    "requiredComponents": [
      "versioned observation, action, and task schemas",
      "deterministic reset, observe, snapshot, restore, and step mechanics",
      "bounded requested-to-applied action adapter",
      "executable success, timeout, and constraint-failure predicates",
      "packet frame, sequence, timestamp, age, and finiteness validation",
      "state-hash replay oracle",
      "fault containment before any position, velocity, sequence, terminal, or RNG mutation",
      "event and predicate trace writer"
    ],
    "buildOrder": [
      "Install the pinned NumPy dependency and run tests/test_task_fixture.py",
      "Freeze packet schemas, units, frames, timestamp semantics, predicates, and precedence",
      "Prove deterministic reset, nominal replay identity, action clipping, and oracle transitions",
      "Inject malformed and wrong-frame packets plus stale and future timestamps on both observation and action packets",
      "Verify every rejected packet leaves the complete simulator state hash unchanged",
      "Run the smoke profile and preserve its manifest, checks, rows, decision, and boundary"
    ],
    "localCommands": [
      "python3 -m pip install -r requirements-capstones.txt",
      "python3 -m unittest tests/test_task_fixture.py",
      "python3 -m unittest discover -s tests -p 'test_*.py'",
      "python3 embodied_capstone_starter.py --project task-contract-capstone --profile smoke --output task-contract-capstone-smoke.json",
      "python3 embodied_capstone_starter.py --verify-dossier task-contract-capstone-smoke.json"
    ],
    "artifacts": [
      "task-contract-capstone-smoke.json",
      "nominal-and-fault-event-rows",
      "state-hash replay receipt",
      "failure.log"
    ]
  },
  "acceptanceChecks": [
    {
      "id": "typed-interface",
      "action": "Validate a nominal packet and one packet with wrong schema version, negative sequence and time, wrong frame, and a non-finite action.",
      "expected": "The nominal packet has no errors, while the malformed packet reports all five contract faults instead of stopping after the first error."
    },
    {
      "id": "nominal-oracle",
      "action": "Replay requested actions 0.07 m and 0.03 m from seed 17 and check every transition with the independent task oracle.",
      "expected": "The first request is clipped to 0.03 m, the second reaches target x=0.06 m, the success predicate terminates, and both trace hashes match."
    },
    {
      "id": "containment",
      "action": "Inject stale and future observation timestamps, stale and future action timestamps, and a wrong action frame at the first sequence number.",
      "expected": "All five branches apply 0.0 m, emit their specific validation error, and preserve identical before/after hashes for position, velocity, sequence, terminal, and RNG state."
    }
  ],

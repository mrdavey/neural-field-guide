  "lessonId": "behavior-cloning-capstone",
  "evidenceKind": "reviewed deterministic local NumPy teaching fixture",
  "starter": {
    "publicUrl": "capstone-artifacts/embodied/embodied_capstone_starter.py",
    "requirementsUrl": "capstone-artifacts/embodied/requirements-capstones.txt",
    "command": "python3 embodied_capstone_starter.py --project behavior-cloning-capstone --profile smoke --output behavior-cloning-capstone-smoke.json",
    "expected": "All eight episode-split, mask, scaling, trainability, checkpoint-resume, nominal rollout, support-departure, and action-ledger checks are true.",
    "boundary": "This command trains and evaluates a small local NumPy linear policy in the deterministic course environment; it is not an external-simulator or physical-robot result."
  },
  "implementation": {
    "requiredComponents": [
      "typed whole-episode trajectory dataset",
      "disjoint train, validation, and test episode splits",
      "observation and action scaling with exact inverse",
      "masked two-field supervised objective",
      "trainable linear policy and momentum optimizer",
      "complete schema-versioned NPZ checkpoint",
      "next-update-equivalent resume branch",
      "closed-loop requested/applied and demonstrated-support evaluator"
    ],
    "buildOrder": [
      "Install the pinned NumPy dependency and run tests/test_dataset.py, tests/test_policy.py, and tests/test_resume.py",
      "Freeze episode lineage, observation fields, action fields, masks, scales, and whole-episode splits",
      "Prove scaling round-trip and one-batch masked-loss reduction",
      "Train direct and interrupted branches from the same seed",
      "Restore weights, optimizer velocity, step counter, scaler, and training episode IDs and prove exact final weights",
      "Evaluate nominal and changed-start closed loops and preserve the checkpoint receipt plus every trace row"
    ],
    "localCommands": [
      "python3 -m pip install -r requirements-capstones.txt",
      "python3 -m unittest tests/test_dataset.py tests/test_policy.py tests/test_resume.py",
      "python3 -m unittest discover -s tests -p 'test_*.py'",
      "python3 embodied_capstone_starter.py --project behavior-cloning-capstone --profile smoke --output behavior-cloning-capstone-smoke.json",
      "python3 embodied_capstone_starter.py --verify-dossier behavior-cloning-capstone-smoke.json"
    ],
    "artifacts": [
      "behavior-cloning-capstone-smoke.json",
      "behavior-cloning-capstone-smoke-bc-checkpoint.npz",
      "checkpoint SHA-256 receipt",
      "nominal-and-changed-start traces",
      "failure.log"
    ]
  },
  "acceptanceChecks": [
    {
      "id": "data-and-loss",
      "action": "Inspect complete episode IDs across splits, compare action-target and mask shapes, invert scaling, and train the masked objective.",
      "expected": "Splits are disjoint by episode, mask and targets share shape, scaling round-trips exactly, and final masked loss is below one percent of its initial value."
    },
    {
      "id": "complete-resume",
      "action": "Interrupt after half the updates, serialize the complete NPZ state, restore it, and finish beside an uninterrupted seed-31 branch.",
      "expected": "Weights, optimizer velocity, step counter, scaler arrays, and training episode IDs are restored; final weight arrays are exactly equal; and the checkpoint path, contents, and SHA-256 receipt are independently verified."
    },
    {
      "id": "closed-loop-support",
      "action": "Run the restored policy from nominal x=0.0 m and changed x=-0.45 m with the same support watchdog and twelve-step horizon.",
      "expected": "The nominal rollout reaches the target autonomously; the changed start departs support at step zero, applies holds, and remains an assisted failure with requested/applied rows."
    }
  ],

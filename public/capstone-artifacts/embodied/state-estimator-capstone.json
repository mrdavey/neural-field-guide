      "nearest valid detection association gate",
      "Kalman-style accepted-measurement update",
      "stale and future camera/proprioception, skewed, out-of-order, and no-match abstention paths",
      "evaluator-only truth join and replay hash"
    ],
    "buildOrder": [
      "Install the pinned NumPy dependency and run tests/test_estimator.py",
      "Freeze frames, transform, time gates, association gate, state fields, and evaluator ownership",
      "Hand-check camera-to-world point and anisotropic covariance rotation",
      "Accept the nearest valid synchronized detection and prove covariance contracts",
      "Exercise stale and future camera/proprioception plus no-association branches without mutating track state",
      "Replay the complete packet trajectory and preserve manifest, rows, checks, decision, and boundary"
    ],
    "localCommands": [
      "python3 -m pip install -r requirements-capstones.txt",
      "python3 -m unittest tests/test_estimator.py",
      "python3 -m unittest discover -s tests -p 'test_*.py'",
      "python3 embodied_capstone_starter.py --project state-estimator-capstone --profile smoke --output state-estimator-capstone-smoke.json",
      "python3 embodied_capstone_starter.py --verify-dossier state-estimator-capstone-smoke.json"
    ],
    "artifacts": [

      "id": "frame-and-covariance",
      "action": "Transform the declared camera point into world coordinates and rotate a strongly anisotropic covariance by ninety degrees.",
      "expected": "The point includes the declared 0.10 m translation and the covariance diagonal swaps axes, demonstrating that uncertainty follows the frame transform."
    },
    {
      "id": "association-update",
      "action": "Process the synchronized near and distractor detections with the declared proprioception delta and 0.25 m association gate.",
      "expected": "Detector near is selected for track-0001, the residual is recorded, and posterior covariance trace is smaller than the predicted prior."
    },
    {
      "id": "abstention-and-lineage",
      "action": "Replay stale and future camera packets, stale and future proprioception packets, and a far unmatched detection while evaluator truth remains outside the estimator API.",
      "expected": "Every invalid-time row abstains without mutating the track, the no-match row expands covariance without an accepted measurement, track-0001 persists, and an exact replay produces the same trace."
    }

    "command": "python3 embodied_capstone_starter.py --project vla-policy-capstone --profile smoke --output vla-policy-capstone-smoke.json",
    "expected": "All nine serializer, masked-self-attention, model-output future-edit, transformer-trainability, language-grounding, diffusion, deterministic-sampling, hard-call-gate, and failure-retention checks are true.",
    "boundary": "This command trains a tiny one-head causal transformer and a diffusion-style noise head locally in NumPy, then decodes deterministic synthetic typed tokens; it does not measure external-simulator quality, accelerator latency, or a physical robot."
  },
  "implementation": {
    "requiredComponents": [
      "typed instruction, vision, and state serializer with validity masks",
      "shared clean action targets and bounded metric action adapter",
      "strictly shifted causal action inputs",
      "trained one-head causal self-attention projections plus metric action head",
      "lower-triangular attention-weight and future-token-edit output-invariance tests",
      "trainable conditional diffusion-style noise head",
      "deterministic bounded three-step sampler",
      "matched update budget, grounding counterfactual, and hard decoder-call gate"
    ],
    "buildOrder": [
      "Install the pinned NumPy dependency and run tests/test_serializer.py, tests/test_causal_targets.py, and tests/test_diffusion_actions.py",
      "Freeze vocabulary, serialization, action units, action bounds, target shift, and validity masks",
      "Execute the causal transformer, inspect zero attention above the diagonal, and prove a future token edit cannot change earlier model outputs",
      "Fit the transformer projections/action head and diffusion noise head for the same 480-update smoke budget",
      "Repeat the deterministic 900-update full profile and verify its parameter/evidence hashes through dossier regeneration",
      "Check the left/right language counterfactual and deterministic bounded diffusion sample",
      "Apply the two-call hard gate before ranking and preserve the failing decoder row"
    ],
    "localCommands": [
      "python3 -m pip install -r requirements-capstones.txt",
      "python3 -m unittest tests/test_serializer.py tests/test_causal_targets.py tests/test_diffusion_actions.py",
      "python3 -m unittest discover -s tests -p 'test_*.py'",
      "python3 embodied_capstone_starter.py --project vla-policy-capstone --profile smoke --output vla-policy-capstone-smoke.json",
      "python3 embodied_capstone_starter.py --verify-dossier vla-policy-capstone-smoke.json",
      "python3 embodied_capstone_starter.py --project vla-policy-capstone --profile full --output vla-policy-capstone-full.json",
      "python3 embodied_capstone_starter.py --verify-dossier vla-policy-capstone-full.json"
    ],
    "artifacts": [
      "vla-policy-capstone-smoke.json",
      "serializer and transformer-causality checks",
      "attention weights plus original/future-edited model outputs",
      "paired transformer/diffusion decoder rows",
      "diffusion denoising trace",
      "failure.log"
    ]
  },
  "acceptanceChecks": [
    {
      "id": "serializer-causality",
      "action": "Serialize a typed language/vision/state example, execute the one-head causal transformer, and edit only a future action token after two earlier prediction positions.",
      "expected": "Modal dtypes and shapes are explicit, attention is lower triangular with zero future weight, padded validity is retained, and the earlier transformer outputs remain exactly invariant to the future edit."
    },
    {
      "id": "train-and-ground",
      "action": "Train every causal-transformer projection and its action head plus the diffusion-style noise head for the matched update budget, then swap the grounded left/right instruction under the same state.",
      "expected": "Both objectives decrease, the transformer tiny-batch loss meets its declared reduction gate, deterministic parameter hashes reproduce for smoke/full, and the language counterfactual changes the requested action sign."
    },
    {
      "id": "hard-call-gate",
      "action": "Decode both arms behind the same action bounds and apply the declared maximum of two decoder calls before considering any quality value.",
      "expected": "The one-call causal transformer is deadline-feasible, the deterministic three-call diffusion row is infeasible, and its denoising trace and failure text remain visible."
    }
  ],
